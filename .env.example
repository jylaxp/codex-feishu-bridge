# New users can run `codex-feishu-bridge setup` to scan a Feishu QR code and
# create this file automatically. Manual setup can copy this file to
# ~/.codex-feishu-bridge/.env. The Bridge reads that private file by default;
# process/service-manager environment values override it.
LARK_APP_ID=cli_0123456789abcdef
LARK_APP_SECRET=replace_me
# Leave these empty for first-run bootstrap. The first private chat message
# from the installer will write tenant/chat/user scope into ~/.codex-feishu-bridge/.env.
LARK_TENANT_KEY=
ALLOWED_CHATS=
AUTHORIZED_USERS=
ALLOWED_APPROVERS=
# Optional local command whitelist for /cmd, /run and /shell.
# Defaults to ls,pwd,git,find,cd; each command still uses a safe argument policy.
# ALLOWED_SHELL_COMMANDS=ls,pwd,git,find,cd

APP_SERVER_MODE=owned_stdio
# APP_SERVER_SOCKET_PATH=/absolute/path/to/app-server.sock

CODEX_BIN=/absolute/path/to/codex
CODEX_CWD=/absolute/path/to/project
ALLOWED_WORKSPACE_ROOTS=/absolute/path/to/project
# Optional. Defaults to ~/.codex-feishu-bridge on the current platform.
BRIDGE_CONFIG_HOME=/absolute/path/to/private/codex-feishu-bridge

MAX_TEXT_LENGTH=10000
CARD_UPDATE_INTERVAL_MS=1500
MAX_QUEUED_TASKS=100

# Legacy settings retained by the Desktop-follower runtime.
RATE_LIMIT_QUERY_INTERVAL_MS=300000
LOG_TO_FILE=false
# Resolved beneath $BRIDGE_CONFIG_HOME/logs when LOG_TO_FILE=true.
LOG_FILE_PATH=bridge.log
# Upload final-answer Markdown file links only when the file is inside an
# authorized workspace root. Images remain card content, not file messages.
ENABLE_AUTO_FILE_UPLOAD=false
