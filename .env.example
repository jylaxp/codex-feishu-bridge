# Codex Feishu Bridge 配置文件
# 推荐运行 `codex-feishu-bridge setup` 扫码并自动创建：
# ~/.codex-feishu-bridge/.env
# 进程或服务管理器提供的环境变量优先于此文件。

# ==================== 配置版本 ====================
# Bridge 配置结构版本，请勿手工修改。
BRIDGE_CONFIG_VERSION=2

# ==================== 飞书应用与访问范围 ====================
# 飞书应用凭证。使用 setup 扫码时自动写入。
LARK_APP_ID=cli_0123456789abcdef
LARK_APP_SECRET=replace_me
# 首次私聊时自动绑定租户、会话和用户；留空即可启用自动绑定。
LARK_TENANT_KEY=
ALLOWED_CHATS=
AUTHORIZED_USERS=
# 可处理审批操作的飞书用户 open_id，多个值使用英文逗号分隔。
ALLOWED_APPROVERS=

# 是否按任务汇总审批卡：0 = 默认，每项审批各发一张卡；1 = 同一任务的全部审批汇总为一张卡。
APPROVAL_SUMMARY_MODE=0

# ==================== ChatGPT App Server ====================
# owned_stdio 表示由 Bridge 启动并管理 App Server 子进程。
# managed_proxy 只用 initialize 佐证远端版本；操作员必须另行保证远端 daemon
# 与 CODEX_BIN 探测选中的 exact profile 和 full schema digest 一致。
APP_SERVER_MODE=owned_stdio
# 仅 managed_proxy 使用外部 socket 时按需配置。
# APP_SERVER_SOCKET_PATH=/absolute/path/to/app-server.sock

# ==================== Codex 运行环境 ====================
# Codex CLI 可执行文件的真实绝对路径。
CODEX_BIN=/absolute/path/to/codex
# setup 会将 CODEX_CWD 自动写成运行时解析出的 Bridge 配置目录。
# 默认配置目录由 os.homedir() 计算，也可以通过进程环境变量
# BRIDGE_CONFIG_HOME 指定其他绝对路径。
CODEX_CWD=/absolute/path/to/resolved/config-home
# /cmd、/run、/shell 可执行的本地命令，多个值使用英文逗号分隔。
ALLOWED_SHELL_COMMANDS=ls,pwd,git,find,cd

# ==================== 飞书卡片与任务队列 ====================
# 单次卡片文本上限。
MAX_TEXT_LENGTH=10000
# 流式卡片刷新间隔，单位为毫秒。
CARD_UPDATE_INTERVAL_MS=1500
# Bridge 内存中的最大排队任务数。
MAX_QUEUED_TASKS=100

# ==================== 用量查询 ====================
# 用量窗口查询间隔，单位为毫秒。
RATE_LIMIT_QUERY_INTERVAL_MS=300000

# ==================== 日志与文件输出 ====================
# true 时写入日志文件；false 时输出到标准输出。
LOG_TO_FILE=false
# 相对路径位于 Bridge 配置目录下，启用文件日志时生效。
LOG_FILE_PATH=bridge.log
# 是否自动上传 Codex 最终回复中引用的本地文件。
ENABLE_AUTO_FILE_UPLOAD=false
