{
  "name": "codex-feishu-bridge",
  "version": "2.0.0",
  "description": "Feishu CardKit bridge for the official Codex App Server event stream",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jylaxp/codex-feishu-bridge.git"
  },
  "main": "dist/app/main.js",
  "bin": {
    "codex-feishu-bridge": "./dist/app/cli.js"
  },
  "files": [
    "dist/app",
    "README.md",
    ".env.example"
  ],
  "scripts": {
    "prepare": "npm run build",
    "build": "npm run build:app",
    "build:app": "npm run clean:app && tsc -p tsconfig.app.json",
    "clean:app": "node scripts/clean-app-build.mjs",
    "start": "node dist/app/cli.js run",
    "doctor": "node dist/app/cli.js doctor",
    "validate:ui-sync": "node dist/app/cli.js validate-ui-sync",
    "typecheck:app": "tsc -p tsconfig.app.json --noEmit",
    "check:app": "npm run typecheck:app && npm run build:app",
    "check:package": "node scripts/check-package.mjs",
    "check": "npm run check:app && npm run check:package"
  },
  "engines": {
    "node": ">=20.17.0 <21"
  },
  "packageManager": "npm@11.16.0",
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.31.0",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "typescript": "^5.3.3"
  }
}
