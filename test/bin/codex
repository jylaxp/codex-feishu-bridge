#!/usr/bin/env node
const readline = require('readline');

// Print arguments to stderr to allow test assertions
console.error(`MOCK_CODEX_ARGS: ${process.argv.slice(2).join(' ')}`);

const rl = readline.createInterface({
  input: process.stdin,
  output: process.stdout,
  terminal: false
});

rl.on('line', (line) => {
  try {
    const req = JSON.parse(line);
    if (req.method === 'initialize') {
      const res = {
        jsonrpc: '2.0',
        id: req.id,
        result: {
          userAgent: 'mock-codex/1.0.0',
          codexHome: '/Users/dummy/.codex',
          platformFamily: 'unix',
          platformOs: 'macos'
        }
      };
      console.log(JSON.stringify(res));
    } else if (req.method === 'thread/read' || req.method === 'thread/resume') {
      const res = {
        jsonrpc: '2.0',
        id: req.id,
        result: {
          thread: {
            id: req.params.threadId,
            name: 'Mock Thread',
            turns: []
          }
        }
      };
      console.log(JSON.stringify(res));
    } else if (req.method === 'thread/list') {
      const res = {
        jsonrpc: '2.0',
        id: req.id,
        result: {
          data: [
            { id: 'thread-123', name: 'Test Session', preview: 'Last message' }
          ]
        }
      };
      console.log(JSON.stringify(res));
    } else if (req.method === 'turn/start') {
      const res = {
        jsonrpc: '2.0',
        id: req.id,
        result: {
          turn: {
            id: 'turn-456'
          }
        }
      };
      console.log(JSON.stringify(res));
      
      // Simulate notifications
      setTimeout(() => {
        console.log(JSON.stringify({
          jsonrpc: '2.0',
          method: 'turn/started',
          params: { threadId: req.params.threadId, turnId: 'turn-456' }
        }));
      }, 20);

      setTimeout(() => {
        console.log(JSON.stringify({
          jsonrpc: '2.0',
          method: 'agent/stdout',
          params: { threadId: req.params.threadId, turnId: 'turn-456', chunk: 'Mock log line 1' }
        }));
      }, 40);

      setTimeout(() => {
        console.log(JSON.stringify({
          jsonrpc: '2.0',
          method: 'turn/completed',
          params: { threadId: req.params.threadId, turnId: 'turn-456' }
        }));
      }, 60);
    }
  } catch (e) {
    console.error('Mock codex error parsing line:', e);
  }
});
